
# Local Supabase CLI defaults; update these if you change the ports in supabase/config.toml.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Copy the local publishable key shown by `supabase status`.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# OAuth credentials used by the local Supabase Auth service.
GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_GITHUB_AUTH_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback
# Server-only Storage credential. Hosted projects should prefer a secret key;
# local Supabase uses the service-role key printed by `supabase status`.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
