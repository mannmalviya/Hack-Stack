# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# editors
.vscode/
.idea/

# misc
.DS_Store
*.pem
CLAUDE.md

# agent tooling (vendored skill docs — regenerate via the tool's CLI; shared config lives in AGENTS.md)
.claude/
.agents/
.github/skills/
.github/copilot-instructions.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.admin.staging.example
!.env.admin.production.example

# supabase (local dev — keep config.toml and migrations tracked)
/supabase/.branches
/supabase/.temp
# data-only dump from `supabase db dump` — large and regenerable, never commit
snapshot.sql

# vercel
.vercel

# trigger.dev (local build artifacts — keep trigger.config.ts and /trigger tracked)
.trigger

# typescript
*.tsbuildinfo
next-env.d.ts

TODO.md
MY_NOTES.md
/docs/

# tmp
/tmp
