# .env.admin.production
# To approve requets run with:
# node --env-file=.env.admin.production --import tsx scripts/approve-hackathon-request.ts

DATABASE_URL="<production Supabase connection string>"
TRIGGER_SECRET_KEY="<production Trigger.dev secret key>"
TRIGGER_PROJECT_REF="<production Trigger.dev project ref>"

# For snapshot loading (scripts: db:load) and cover-image sync (scripts/sync-storage.ts)
DEST_SUPABASE_URL="<production Supabase project URL, e.g. https://abcd1234.supabase.co>"
DEST_SUPABASE_SERVICE_ROLE_KEY="<production Supabase service_role key>"