# .env.admin.staging
# To approve requets run with:
# node --env-file=.env.admin.staging --import tsx scripts/approve-hackathon-request.ts

DATABASE_URL="<staging Supabase connection string>"
TRIGGER_SECRET_KEY="<staging Trigger.dev secret key>"
TRIGGER_PROJECT_REF="<staging Trigger.dev project ref>"

# For snapshot loading (scripts: db:load) and cover-image sync (scripts/sync-storage.ts)
DEST_SUPABASE_URL="<staging Supabase project URL, e.g. https://abcd1234.supabase.co>"
DEST_SUPABASE_SERVICE_ROLE_KEY="<staging Supabase service_role key>"